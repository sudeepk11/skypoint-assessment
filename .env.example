# --- Ports (change if 3000 or 8000 are already in use on your machine) ---
APP_PORT=3000
BACKEND_PORT=8000

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=skypoint_db
DATABASE_URL=postgresql://postgres:postgres@db:5432/skypoint_db

# --- JWT Auth ---
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Cookie (set to true when serving over HTTPS in production) ---
COOKIE_SECURE=false

# --- AWS SES (Optional — required only for bulk email feature) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_REGION=us-east-1
AWS_SES_FROM_EMAIL=
